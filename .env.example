# Server port. Hosting platforms (Render, etc.) inject PORT automatically and
# it takes precedence; API_PORT is the local fallback. Default 8787.
API_PORT=8787

# ---------------------------------------------------------------------------
# API authentication
# ---------------------------------------------------------------------------
# Shared secret that gates every /api route (except /api/health and the
# Telegram webhook). UNSET = the API is open — fine on localhost only.
# Generate one:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Then in the browser console once:  localStorage.setItem("msos.apiKey", "<the key>")
MATCH_SIGNAL_API_KEY=

# Optional hardening for the Telegram webhook (which can't carry the API key).
# Register it via setWebhook's secret_token parameter with this same value;
# Telegram echoes it back as X-Telegram-Bot-Api-Secret-Token on every update.
TELEGRAM_WEBHOOK_SECRET=
# PORT=

# Optional: path to a local whisper.cpp model (.bin) for /api/video/transcribe.
# If unset, the transcribe service looks in ./models/. See transcribe.mjs.
# WHISPER_MODEL_PATH=

# ---------------------------------------------------------------------------
# AI content generation
# ---------------------------------------------------------------------------
# Gemini powers ALL AI content (editorial + betting angle), team ratings, and
# the football-semantic video scan. This is the model key the code actually
# uses — see server/services/gemini.mjs and server/services/video/geminiScan.mjs.
GEMINI_API_KEY=

# LEGACY / UNUSED: the codebase no longer calls OpenAI. These are kept only so
# old .env files don't break; safe to leave blank or delete.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# ---------------------------------------------------------------------------
# Football data sources
# ---------------------------------------------------------------------------
# football-data.org v4 API token
FOOTBALL_DATA_TOKEN=

# Sportradar Soccer API
SPORTRADAR_API_KEY=
SPORTRADAR_SOCCER_PRODUCT=soccer
SPORTRADAR_ACCESS_LEVEL=trial
SPORTRADAR_LANGUAGE=en
# Optional override for the World Cup 2026 season id used by fixtures sync.
SPORTRADAR_WORLD_CUP_2026_SEASON_ID=sr:season:101177

# The Odds API (decimal odds for VIP picks + market context)
ODDS_API_KEY=

# ---------------------------------------------------------------------------
# Telegram
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
# Optional. Use only if local DNS routes api.telegram.org to an unreachable IP.
# Keeps TLS hostname as api.telegram.org while connecting to this IPv4 address.
TELEGRAM_API_CONNECT_IP=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_PUBLIC_CHANNEL_ID=
# VIP picks channel (gated — see the VIP layer block below). Leave blank to
# keep VIP publishing disabled.
TELEGRAM_BETTING_CHANNEL_ID=
# Optional. Defaults to enabled. Set to "false" to receive inbound updates only
# through a deployed webhook instead of the local polling worker.
TELEGRAM_POLLING_ENABLED=true

# ---------------------------------------------------------------------------
# VIP picks layer (server/services/picks.mjs + /api/telegram/vip)
# ---------------------------------------------------------------------------
# All four gates must pass before /api/telegram/vip will publish:
#   1. TELEGRAM_BOT_TOKEN configured
#   2. TELEGRAM_BETTING_CHANNEL_ID configured
#   3. VIP_JURISDICTIONS set to a non-empty comma-separated list (operator
#      explicitly opts in per region)
#   4. VIP_PUBLISH_ENABLED is not "false"
VIP_JURISDICTIONS=
VIP_PUBLISH_ENABLED=false

# Picks tuning (defaults shown; all optional)
KELLY_FRACTION=0.25
MAX_STAKE_UNITS=2.0
MIN_STAKE_UNITS=0.25
MIN_EV=0.04
PICKS_TEMP_SCALE=4.0
PICKS_DRAW_WEIGHT=0.27

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
# Run supabase/schema.sql (or the migrations) first. Service-role key is most
# reliable for server writes; publishable-key writes depend on table policies.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Google Sheets API service account
# ---------------------------------------------------------------------------
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ---------------------------------------------------------------------------
# n8n automation
# ---------------------------------------------------------------------------
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
N8N_DAILY_BRIEF_WEBHOOK=
N8N_PRE_MATCH_WEBHOOK=
N8N_POST_MATCH_WEBHOOK=
N8N_REPORT_WEBHOOK=
# n8n MCP server status check (GET /api/n8n/mcp/status)
N8N_MCP_URL=
N8N_MCP_TOKEN=

# ---------------------------------------------------------------------------
# Social publishing vendors
# ---------------------------------------------------------------------------
# Primary provider: buffer (GraphQL adapter, working), ayrshare, uploadpost,
# or postproxy (generic REST). SOCIAL_DRY_RUN=true previews without publishing.
SOCIAL_PRIMARY_PROVIDER=buffer
SOCIAL_DRY_RUN=true

# Football video source discovery
# ScoreBat free feed works without a key. Paid plans unlock team/competition endpoints.
SCOREBAT_API_KEY=
# Highlightly requires an API key. Set HIGHLIGHTLY_USE_RAPIDAPI=true if using RapidAPI.
HIGHLIGHTLY_API_KEY=
HIGHLIGHTLY_USE_RAPIDAPI=false
RAPIDAPI_KEY=

BUFFER_API_KEY=
BUFFER_BASE_URL=https://api.buffer.com
BUFFER_PUBLISH_PATH=/graphql

POSTPROXY_API_KEY=
POSTPROXY_BASE_URL=
POSTPROXY_PUBLISH_PATH=/posts

AYRSHARE_API_KEY=
AYRSHARE_BASE_URL=https://api.ayrshare.com/api
AYRSHARE_PUBLISH_PATH=/post

UPLOAD_POST_API_KEY=
UPLOAD_POST_BASE_URL=
UPLOAD_POST_PUBLISH_PATH=/posts

# Official social API credentials, used only when we build direct integrations
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
YOUTUBE_API_KEY=
YOUTUBE_OWNED_CHANNEL_IDS=
YOUTUBE_CREATIVE_COMMONS_ONLY=false
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=
