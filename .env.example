API_PORT=8787

# OpenAI Responses API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# football-data.org v4 API token
FOOTBALL_DATA_TOKEN=

# Sportradar Soccer API
SPORTRADAR_API_KEY=
SPORTRADAR_SOCCER_PRODUCT=soccer
SPORTRADAR_ACCESS_LEVEL=trial
SPORTRADAR_LANGUAGE=en

# Telegram Bot API
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_PUBLIC_CHANNEL_ID=

# Supabase
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Sheets API service account
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# n8n webhook URLs
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
N8N_DAILY_BRIEF_WEBHOOK=
N8N_PRE_MATCH_WEBHOOK=
N8N_POST_MATCH_WEBHOOK=
N8N_REPORT_WEBHOOK=

# Social publishing vendors
# Pick one primary provider after account setup: postproxy, ayrshare, uploadpost
SOCIAL_PRIMARY_PROVIDER=postproxy
SOCIAL_DRY_RUN=true

BUFFER_API_KEY=
BUFFER_BASE_URL=https://api.buffer.com
BUFFER_PUBLISH_PATH=/graphql

POSTPROXY_API_KEY=
POSTPROXY_BASE_URL=
POSTPROXY_PUBLISH_PATH=/posts

AYRSHARE_API_KEY=
AYRSHARE_BASE_URL=https://api.ayrshare.com/api
AYRSHARE_PUBLISH_PATH=/post

UPLOAD_POST_API_KEY=
UPLOAD_POST_BASE_URL=
UPLOAD_POST_PUBLISH_PATH=/posts

# Official social API credentials, used only when we build direct integrations
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=
